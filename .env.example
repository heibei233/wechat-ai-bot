# AI provider: deepseek (cloud API) | ollama (local, no censorship)
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Ollama local model (used when AI_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=huihui_ai/deepseek-r1-abliterated:32b

# console | wechaty | wecom | kefu
BOT_ADAPTER=console

# Keep replies short and WeChat-like.
BOT_SYSTEM_PROMPT=你是一个微信聊天助手。回复自然、简洁、有帮助，像真人聊天一样，不要机械地列太多条。

# Comma-separated user names or remarks. Leave empty to allow everyone in private chats.
ALLOW_PRIVATE_CONTACTS=

# Comma-separated group topic names. Leave empty to allow all groups, but the bot still replies only when mentioned.
ALLOW_ROOMS=

# Personal WeChat automation is not an official WeChat Open Platform API.
# Depending on the puppet you use, you may need:
# WECHATY_PUPPET=wechaty-puppet-service
# WECHATY_PUPPET_SERVICE_TOKEN=your-token

# QR code web display port (so you can scan from any device on LAN)
# QR_PORT=3000

# ═══════════════════════════════════════════════════
# 企业微信 (WeCom) adapter — official API, stable
# Get these from 企业微信管理后台 → 应用管理 → 自建应用
# ═══════════════════════════════════════════════════
# WECOM_CORP_ID=your-corp-id
# WECOM_AGENT_ID=1000002
# WECOM_AGENT_SECRET=your-agent-secret
# WECOM_TOKEN=your-callback-token
# WECOM_ENCODING_AES_KEY=your-43-char-encoding-aes-key

# ═══════════════════════════════════════════════════
# 微信客服 (Kefu) — 个人微信直接跟 bot 聊天
# Get these from 企业微信管理后台 → 应用管理 → 微信客服
# ═══════════════════════════════════════════════════
# WECOM_KEFU_OPEN_KFID=your-kefu-account-id
# WECOM_KEFU_TOKEN=your-kefu-callback-token
# WECOM_KEFU_AES_KEY=your-kefu-43-char-encoding-aes-key
